<%- include('partials/header') %>

<!-- Main Organizations Content -->
<h2>Our Partner Organizations & Academic Events</h2>
<p>Discover the institutions, graduation milestones, and civic achievements that shape our educational ecosystem.</p>

<!-- Organizations Section Container -->
<div class="organizations-container">
    
<% if (organizations && organizations.length > 0) { %>
    <% organizations.forEach(function(org) { %>
        <!-- Dynamic Organization Card -->
        <div class="org-card">
            <img src="/images/<%= org.logo_filename %>" alt="<%= org.name %>">
            <div class="org-text">
                <h3><%= org.name %></h3>
                <p><%= org.description %></p>
            </div>
        </div>
    <% }); %>
<% } else { %>
    <p>No organizations found.</p>
<% } %>
</div>

<%- include('partials/footer') %>


</div>

<%- include('partials/footer') %>
